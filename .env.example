# ============================================================================
# ModelServe — Environment Variables Reference
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# ============================================================================

# ── PostgreSQL (consumed by: postgres service, mlflow service) ───────────────
POSTGRES_USER=mlflow
POSTGRES_PASSWORD=mlflow
POSTGRES_DB=mlflow

# ── MLflow Tracking Server (consumed by: mlflow service, api service) ────────
# Local dev: http://mlflow:5000 (inside Docker network)
# Production: http://<EC2-IP>:5000
MLFLOW_TRACKING_URI=http://mlflow:5000

# Name of the registered model in MLflow Registry
MLFLOW_MODEL_NAME=fraud_detector

# MLflow artifact storage root
# Local dev: /mlflow/artifacts  (Docker volume)
# Production: s3://<bucket-name>/mlflow-artifacts
MLFLOW_ARTIFACT_ROOT=/mlflow/artifacts

# ── FastAPI / Model inference (consumed by: api service) ─────────────────────
# Path to the Feast feature repo inside the container
FEAST_REPO_PATH=/app/feast_repo

# Redis connection URL for Feast online store
REDIS_URL=redis://redis:6379

# ── Redis (consumed by: api service via Feast, feast_repo/feature_store.yaml) ─
REDIS_HOST=redis
REDIS_PORT=6379

# ── Grafana (consumed by: grafana service) ───────────────────────────────────
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin
GF_USERS_ALLOW_SIGN_UP=false

# ── AWS (consumed by: EC2 instance profile in production; CLI on Poridhi VM) ──
# These are provided by the Poridhi sandbox each session.
# In production, the EC2 IAM instance profile supplies credentials automatically.
AWS_ACCESS_KEY_ID=<from-poridhi-sandbox>
AWS_SECRET_ACCESS_KEY=<from-poridhi-sandbox>
AWS_DEFAULT_REGION=ap-southeast-1
